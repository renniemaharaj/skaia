{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skaia.dev/schemas/page-sections/section-preset.v1.schema.json",
  "title": "Skaia section preset v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": { "type": "integer", "minimum": 1 },
    "name": { "type": "string", "minLength": 1, "maxLength": 160 },
    "description": { "type": "string", "maxLength": 2000 },
    "section_type": {
      "enum": [
        "hero",
        "card_group",
        "stat_cards",
        "social_links",
        "image_gallery",
        "feature_grid",
        "cta",
        "event_highlights",
        "profile_card",
        "rich_text",
        "code_editor",
        "data_sources",
        "derived_section",
        "custom_section",
        "form",
        "qa",
        "survey",
        "poll",
        "vote"
      ]
    },
    "shell_version": { "const": 1 },
    "shell": {
      "$ref": "https://skaia.dev/schemas/page-sections/shared-section-shell.v1.schema.json"
    },
    "config_version": { "const": 1 },
    "config": { "type": "object" },
    "items": {
      "type": "array",
      "maxItems": 500,
      "items": { "$ref": "https://skaia.dev/schemas/page-sections/page-item.v1.schema.json" }
    },
    "revision": { "type": "integer", "minimum": 1 }
  },
  "required": [
    "id",
    "name",
    "description",
    "section_type",
    "shell_version",
    "shell",
    "config_version",
    "config",
    "items",
    "revision"
  ]
}
