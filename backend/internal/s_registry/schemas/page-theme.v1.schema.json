{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skaia.dev/schemas/page-sections/page-theme.v1.schema.json",
  "title": "Skaia custom page theme v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": {
      "const": 1
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "tokens": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "value": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "format": "css-color"
          },
          "display_order": {
            "type": "integer",
            "minimum": 0,
            "maximum": 63
          },
          "revision": {
            "type": "integer",
            "minimum": 1
          }
        },
        "required": ["key", "label", "value", "display_order", "revision"]
      }
    }
  },
  "required": ["version", "revision", "tokens"]
}
