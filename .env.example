# ─────────────────────────────────────────────────────────────────────────────
# Skaia — Shared infrastructure configuration
#
# Copy this file to .env and fill in values:
#   cp .env.example .env
#
# These credentials are used by the shared PostgreSQL instance and are
# referenced by grengo when creating per-client databases.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL superuser (shared across all tenants)
POSTGRES_USER=skaia
POSTGRES_PASSWORD=changeme
PGPORT=5432
